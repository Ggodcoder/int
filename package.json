{
  "name": "int-cli",
  "version": "0.1.0",
  "description": "A forest-to-leaf knowledge CLI with FSRS flashcards.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ggodcoder/int.git"
  },
  "files": [
    "src",
    "README.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "bin": {
    "int": "./src/cli.mjs"
  },
  "scripts": {
    "start": "node ./src/cli.mjs",
    "smoke": "node ./src/cli.mjs --smoke",
    "test:prompt": "node --test tests/prompt.test.mjs",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@inquirer/core": "^11.1.9",
    "playwright": "^1.59.1",
    "ts-fsrs": "^5.3.2"
  },
  "engines": {
    "node": ">=20.12"
  },
  "devDependencies": {
    "@inquirer/testing": "^3.3.5"
  }
}
